<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full text-white h-screen bg-zinc-900 p-10">
       <a class=" w-20 px-3 py-2 text-sm bg-red-500 block rounded-md mt-2 mb-2 inline-block" href="/logout">Logout</a>

       <h4 class="mb-5">You can edit a post.</h4>
       <form method="post"  action="/update/<%= post._id %>">
             <textarea placeholder="What's on your mind?" class=" w-1/3 resize-none bg-transparent border-2 border-zinc-100 rounded-md" name="content"><%=post.content %></textarea>
             <input  class=" w-40 px-3 py-2 text-sm bg-yellow-500 block rounded-md mt-2" type="submit" value="Update Post">
       </form>
       
    </div>
    
</body>
</html>