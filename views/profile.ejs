<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full text-white h-screen bg-zinc-900 p-10">
       <a class=" w-20 px-3 py-2 text-sm bg-red-500 block rounded-md mt-2 mb-2 inline-block" href="/logout">Logout</a>
       <div class="flex">
            <div class="w-10 h-10  rounded-md overflow-hidden">
                <img class="w-full h-full object-cover " src="/images/uploads/<%= user.profilepic%>" alt="">
            </div>
            <h3 class="text-3xl text-white mb-5"><span class="font-light">Hello</span>, <%= user.name %> 🫸🎉</h3>
       </div>
       
       <h4 class=" mb-5">You can create a new post.</h4>
       <form method="post"  action="/post">
             <textarea placeholder="What's on your mind?" class=" w-1/3 resize-none bg-transparent border-2 border-zinc-100 rounded-md" name="content" ></textarea>
             <input  class=" w-40 px-3 py-2 text-sm bg-blue-500 block rounded-md mt-2" type="submit" value="Create New Post">
       </form>
       <div class="posts mt-10">
        <h3>Your Posts </h3>
            <h3 class="text-zinc-400"></h3>
            <div class="postcontainer mt-5" flex flex-wrap >
               <% user.posts.reverse().forEach(function(post){ %>
                 <div class="post w-1/3 mb-2 p-4 rounded-md border-2 border-zinc-700">
                    <h4 class="text-blue-500 mb-3">@<%= user.username%></h4>
                    <p class="text-sm tracking-tight"><%= post.content %></p>
                    <small class="mt-2 inline-block"><%= post.likes.length %>likes</small>
                    <div class="btns flex gap-4">
                        <a class="text-blue-500" href="/like/<%= post._id %>">
                            <%= post.likes.indexOf(user._id) === -1 ? "Like": "Unlike" %>
                        </a>
                        <a class="text-zinc-600" href="/edit/<%=post._id %>">edit</a>
                    </div>
                </div>

               <% }) %>
            </div>
       </div> 
    </div>
    
</body>
</html>