<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10">
        <h3 class="text-3xl text-white">Upload Profile Picture</h3>
        <form autocomplete="off" action="/upload" method="post" enctype="multipart/form-data">
            <input class="text-white" type="file" name="image">
        
            <input class="px-5 py-2 bg-blue-500 rounded-md text-white" type="submit" value="Upload File">
        </form>
       
    </div>
    
</body>
</html>